# ===========================
# منصة بصيرة - متغيرات البيئة
# ===========================
# انسخ هذا الملف إلى .env وعدّل القيم المناسبة
# لا ترفع ملف .env إلى Git أبداً

# البيئة (development | staging | production)
BASEERA_ENV=development

# ===========================
# LLM Configuration
# ===========================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ===========================
# Database
# ===========================
DATABASE_URL=postgresql://user:password@localhost:5432/baseera_db

# ===========================
# Security
# ===========================
# As of M2.12, both keys below are real and read: SECRET_KEY signs/
# verifies JWTs (src/api/auth/jwt_handler.py) and derives the fixed
# password-hashing salt (src/api/auth/password.py); API_KEY is the
# single configured value the X-API-Key header is checked against
# (src/api/auth/api_key.py). Neither had a real reader before M2.12.
SECRET_KEY=your_secret_key_here
API_KEY=your_api_key_here

# The single foundation admin account src/api/routes/auth.py's
# POST /auth/login checks against -- there is no multi-user table yet,
# see src/api/auth/__init__.py for why. ADMIN_PASSWORD_HASH is the
# hex digest src.api.auth.password.hash_password(plaintext, SECRET_KEY)
# produces, never a plaintext password.
ADMIN_USERNAME=your_admin_username_here
ADMIN_PASSWORD_HASH=

# Optional overrides (sensible defaults in src/api/config.py if unset).
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=900
JWT_REFRESH_TOKEN_EXPIRE_SECONDS=604800

# Comma-separated browser origins allowed to call the API (CORS).
# Empty/unset means no browser origin is allowed, deliberately -- see
# src/api/config.py's get_cors_allowed_origins().
CORS_ALLOWED_ORIGINS=

# Per-client-IP fixed-window rate limit (src/api/middleware/rate_limit.py).
RATE_LIMIT_REQUESTS_PER_WINDOW=60
RATE_LIMIT_WINDOW_SECONDS=60

# ===========================
# Saudi Market Data
# ===========================
# No licensed Tadawul data vendor is contracted yet (as of M2.1) -- this
# key has no real provider behind it. src/market_data/providers/
# dev_market_data_provider.py is the interim, synthetic-data-only
# provider used until a vendor is chosen; it does not read this key.
TADAWUL_API_KEY=your_tadawul_api_key_here

# As of M2.13: which IMarketDataProvider src/market_data/provider_factory.py
# builds -- "dev" (synthetic, default) or "sahmak" (real Sahmak API client,
# src/market_data/providers/sahmak_market_data_provider.py). No vendor
# contract exists yet, so "sahmak" is wired but unverified against a live
# endpoint until real credentials below are configured.
MARKET_DATA_PROVIDER=dev
SAHMAK_API_KEY=
SAHMAK_API_SECRET=
SAHMAK_BASE_URL=

# Optional overrides (sensible defaults in src/market_data/config.py if unset).
MARKET_DATA_MAX_RETRIES=3
MARKET_DATA_TIMEOUT_SECONDS=30
MARKET_DATA_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
MARKET_DATA_CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=30
MARKET_DATA_QUOTE_CACHE_TTL_SECONDS=60
