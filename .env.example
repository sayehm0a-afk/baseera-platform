# ===========================
# منصة بصيرة - متغيرات البيئة
# ===========================
# انسخ هذا الملف إلى .env وعدّل القيم المناسبة
# لا ترفع ملف .env إلى Git أبداً

# البيئة (development | staging | production)
BASEERA_ENV=development

# ===========================
# LLM Configuration
# ===========================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ===========================
# Database
# ===========================
DATABASE_URL=postgresql://user:password@localhost:5432/baseera_db

# ===========================
# Security
# ===========================
SECRET_KEY=your_secret_key_here
API_KEY=your_api_key_here

# ===========================
# Saudi Market Data
# ===========================
TADAWUL_API_KEY=your_tadawul_api_key_here
